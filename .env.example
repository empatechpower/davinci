# Supabase PostgreSQL (Transaction Pooler — use port 6543 for serverless/Vercel)
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth — https://developers.facebook.com → My Apps → your app → Settings → Basic
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# HitPay — https://dashboard.sandbox.hit-pay.com/settings/api
HITPAY_API_KEY=
HITPAY_WEBHOOK_SALT=

# Your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Instagram Feed (Gallery page)
# Get a long-lived token from: https://developers.facebook.com/docs/instagram-basic-display-api/guides/long-lived-access-tokens
INSTAGRAM_ACCESS_TOKEN=
NEXT_PUBLIC_INSTAGRAM_HANDLE=DaVinciProject
